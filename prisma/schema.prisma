generator client {
  provider      = "prisma-client-js"
  // "native" yerel geliştirme, "rhel-openssl-3.0.x" Netlify (AWS Lambda) içindir.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  discordId   String   @unique
  username    String
  globalName  String?
  avatar      String?
  email       String?
  createdAt   DateTime @default(now())
  lastLoginAt DateTime @default(now())

  // Kullanıcının yönetici (Manage Server) olduğu sunucuların son giriş anındaki
  // anlık görüntüsü: [{ id, name, icon, owner, permissions }]
  guilds      Json?

  profile    Profile?
  transfers  Transfer[]
  orders     Order[]
  botConfigs BotConfig[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  total     Float
  status    String      @default("aktif") // aktif | beklemede | iptal
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  title       String
  kind        String // bot | paket | website | hizmet
  unitPrice   Float
  periodLabel String
  qty         Int    @default(1)
}

model BotConfig {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String // hangi bot (BOTS[].id)
  guildId         String
  guildName       String?
  logChannelId    String?
  enabledCommands Json? // string[] — açık komut/özellik anahtarları
  settings        Json? // ileride genişleyecek ek ayarlar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, productId, guildId])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  billingType String  @default("bireysel") // bireysel | kurumsal
  firstName   String?
  lastName    String?
  email       String?
  address1    String?
  address2    String?
  district    String?
  city        String?
  postalCode  String?
  country     String?
  tcNo        String?
  taxOffice   String?
  taxNo       String?
  companyName String?

  updatedAt DateTime @updatedAt
}

model Transfer {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetDiscordId String
  status          String   @default("beklemede") // beklemede | tamamlandi | reddedildi
  createdAt       DateTime @default(now())
}
